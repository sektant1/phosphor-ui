{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "src/global.d.ts",
    ".storybook/**/*.ts",
    "src/**/*.stories.tsx",
    "src/**/*.stories.mdx",
    "src/demo/**/*.ts",
    "src/demo/**/*.tsx",
    "src/stories/**/*.ts",
    "src/stories/**/*.tsx",
    "src/stories/**/*.mdx"
  ],
  "exclude": ["node_modules", "dist", "storybook-static"]
}
