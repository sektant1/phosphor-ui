{
  "name": "@sektant1/phosphor-ui",
  "version": "0.2.0",
  "description": "Phosphor UI — single-channel green-phosphor React component library. Retro/military/cyberpunk CRT aesthetic.",
  "keywords": [
    "react",
    "components",
    "design-system",
    "ui",
    "phosphor",
    "crt",
    "retro",
    "cyberpunk",
    "terminal",
    "storybook"
  ],
  "author": "sektant1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sektant1/phosphor.git"
  },
  "homepage": "https://github.com/sektant1/phosphor#readme",
  "bugs": {
    "url": "https://github.com/sektant1/phosphor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/types/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./global.css": "./dist/global.css",
    "./fonts/VT323-Regular.ttf": "./dist/fonts/VT323-Regular.ttf"
  },
  "scripts": {
    "build": "rollup -c && npm run copy-styles",
    "rollup": "rollup -c",
    "copy-styles": "mkdir -p dist/fonts && cp src/styles/tokens.css dist/tokens.css && cp src/styles/global.css dist/global.css && cp src/styles/fonts/VT323-Regular.ttf dist/fonts/VT323-Regular.ttf",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook",
    "prepublishOnly": "npm run typecheck && npm run build",
    "release": "npm publish --access public"
  },
  "peerDependencies": {
    "@mdx-js/react": "^2",
    "react": "^17 || ^18",
    "react-dom": "^17 || ^18"
  },
  "peerDependenciesMeta": {
    "@mdx-js/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.16.0",
    "@babel/preset-env": "^7.16.4",
    "@babel/preset-react": "^7.16.0",
    "@babel/preset-typescript": "^7.16.0",
    "@mdx-js/react": "^2.1.2",
    "@rollup/plugin-commonjs": "^21.0.1",
    "@rollup/plugin-node-resolve": "^13.0.6",
    "@rollup/plugin-typescript": "^8.3.0",
    "@storybook/addon-actions": "^6.5.9",
    "@storybook/addon-essentials": "^6.5.9",
    "@storybook/addon-links": "^6.5.9",
    "@storybook/builder-webpack5": "^6.5.9",
    "@storybook/manager-webpack5": "^6.5.9",
    "@storybook/preset-scss": "^1.0.3",
    "@storybook/react": "^6.5.9",
    "@testing-library/react": "^13.3.0",
    "@types/jest": "^28.1.6",
    "@types/react": "^18.0.15",
    "babel-jest": "^27.3.1",
    "babel-loader": "^8.2.3",
    "css-loader": "^6.5.1",
    "figlet": "^1.7.0",
    "html-webpack-plugin": "^5.5.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^28.1.3",
    "jest-environment-jsdom": "^28.1.3",
    "postcss": "^8.5.14",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup": "^2.60.0",
    "rollup-plugin-dts": "^4.0.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.1",
    "rollup-plugin-terser": "^7.0.2",
    "sass": "^1.43.5",
    "sass-loader": "^12.3.0",
    "style-loader": "^3.3.1",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "shiki": "^1.29.2"
  }
}
