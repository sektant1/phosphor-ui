{
  "name": "@sektant1/phosphor-ui",
  "version": "0.3.9",
  "description": "Phosphor UI — single-channel green-phosphor React component library. Retro/military/cyberpunk CRT aesthetic.",
  "keywords": [
    "react",
    "components",
    "design-system",
    "ui",
    "phosphor",
    "crt",
    "retro",
    "cyberpunk",
    "terminal",
    "storybook"
  ],
  "author": "sektant1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sektant1/phosphor.git"
  },
  "homepage": "https://github.com/sektant1/phosphor#readme",
  "bugs": {
    "url": "https://github.com/sektant1/phosphor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./global.css": "./dist/global.css",
    "./fonts/JetBrainsMono-Regular.woff2": "./dist/fonts/JetBrainsMono-Regular.woff2",
    "./fonts/JetBrainsMono-Bold.woff2": "./dist/fonts/JetBrainsMono-Bold.woff2",
    "./fonts/JetBrainsMono-Italic.woff2": "./dist/fonts/JetBrainsMono-Italic.woff2",
    "./fonts/SpaceMono-Regular.woff2": "./dist/fonts/SpaceMono-Regular.woff2",
    "./fonts/SpaceMono-Bold.woff2": "./dist/fonts/SpaceMono-Bold.woff2",
    "./fonts/SpaceMono-Italic.woff2": "./dist/fonts/SpaceMono-Italic.woff2",
    "./fonts/VT323-Regular.ttf": "./dist/fonts/VT323-Regular.ttf"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs && npm run build:types && npm run copy-styles",
    "rollup": "rollup -c rollup.config.mjs",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --declarationDir dist/esm --outDir dist/esm",
    "copy-styles": "mkdir -p dist/fonts && cp src/styles/tokens.css dist/tokens.css && cp src/styles/global.css dist/global.css && cp src/styles/fonts/* dist/fonts/",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run typecheck && npm run build",
    "release": "npm publish --access public"
  },
  "peerDependencies": {
    "@mdx-js/react": "^2 || ^3",
    "react": "^17 || ^18 || ^19",
    "react-dom": "^17 || ^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@mdx-js/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "@mdx-js/react": "3.1.1",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@storybook/addon-actions": "8.6.18",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-links": "8.6.18",
    "@storybook/react-webpack5": "8.6.18",
    "@storybook/test": "8.6.18",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/video.js": "^7.3.58",
    "babel-jest": "30.3.0",
    "babel-loader": "10.1.1",
    "css-loader": "7.1.4",
    "figlet": "1.11.0",
    "html-webpack-plugin": "5.6.7",
    "identity-obj-proxy": "3.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "postcss": "8.5.14",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rollup": "4.60.3",
    "rollup-plugin-dts": "6.4.1",
    "rollup-plugin-peer-deps-external": "2.2.4",
    "rollup-plugin-postcss": "4.0.2",
    "sass": "1.99.0",
    "sass-loader": "16.0.7",
    "storybook": "8.6.18",
    "style-loader": "4.0.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "shiki": "4.0.2",
    "video.js": "^8.23.7"
  }
}
